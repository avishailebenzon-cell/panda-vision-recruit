{
  "name": "CreditLog",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05d4\u05de\u05e9\u05ea\u05de\u05e9 \u05e9\u05e6\u05e8\u05da \u05d0\u05ea \u05d4\u05e7\u05e8\u05d3\u05d9\u05d8\u05d9\u05dd"
    },
    "user_name": {
      "type": "string",
      "description": "\u05e9\u05dd \u05d4\u05de\u05e9\u05ea\u05de\u05e9"
    },
    "user_email": {
      "type": "string",
      "description": "\u05d0\u05d9\u05de\u05d9\u05d9\u05dc \u05d4\u05de\u05e9\u05ea\u05de\u05e9"
    },
    "action_type": {
      "type": "string",
      "description": "\u05e1\u05d5\u05d2 \u05d4\u05e4\u05e2\u05d5\u05dc\u05d4 \u05e9\u05e6\u05e8\u05db\u05d4 \u05e7\u05e8\u05d3\u05d9\u05d8\u05d9\u05dd (InvokeLLM, SearchCandidates, GenerateImage, \u05d5\u05db\u05d5')"
    },
    "model_used": {
      "type": "string",
      "description": "\u05d4\u05de\u05d5\u05d3\u05dc \u05e9\u05e0\u05d5\u05e6\u05dc (gpt-4o-mini, claude_sonnet, gemini_flash \u05d5\u05db\u05d5')"
    },
    "credits_used": {
      "type": "number",
      "description": "\u05db\u05de\u05d5\u05ea \u05e7\u05e8\u05d3\u05d9\u05d8\u05d9\u05dd \u05e9\u05e0\u05e6\u05e8\u05db\u05d4"
    },
    "description": {
      "type": "string",
      "description": "\u05ea\u05d9\u05d0\u05d5\u05e8 \u05d4\u05e4\u05e2\u05d5\u05dc\u05d4"
    },
    "page_context": {
      "type": "string",
      "description": "\u05d4\u05e7\u05e9\u05e8 \u05d4\u05d3\u05e3/\u05e4\u05d5\u05e0\u05e7\u05e6\u05d9\u05d4 \u05e9\u05de\u05d4 \u05d4\u05e4\u05e2\u05d5\u05dc\u05d4 \u05d1\u05d5\u05e6\u05e2\u05d4"
    }
  },
  "required": [
    "user_id",
    "user_name",
    "credits_used",
    "action_type"
  ]
}