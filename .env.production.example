# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env.production and fill in actual values for production deployment
# NEVER commit actual .env.production file to git - it contains secrets

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string (required for production)
# Format: postgresql://user:password@host:port/database
# For Render: postgresql://postgres:PASSWORD@dpg-xxxxx.postgres.render.com:5432/dbname
DATABASE_URL=postgresql://postgres:PASSWORD@postgres-host:5432/panda_vision

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# JWT secret key for authentication (MUST be changed in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_IN_PRODUCTION

# Application mode
DEBUG=false
APP_NAME=Panda Vision Recruit
APP_VERSION=1.0.0

# ============================================================================
# CORS & FRONTEND CONFIGURATION
# ============================================================================
# Frontend URL for CORS headers
# For Render: https://your-frontend-domain.vercel.app or https://your-domain.com
FRONTEND_URL=https://your-frontend-url.com
ALLOWED_ORIGINS=https://your-frontend-url.com,https://www.your-domain.com

# ============================================================================
# EMAIL SCANNING (AZURE)
# ============================================================================
# Azure/Microsoft 365 credentials for email scanning
# Register app at https://entra.microsoft.com/
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Email address to monitor (jobs@ mailbox)
EMAIL_ADDRESS=jobs@pandatech.co.il

# Email scanning configuration
EMAIL_SCAN_INTERVAL_MINUTES=30
EMAIL_SCAN_LIMIT=50

# ============================================================================
# PIPEDRIVE INTEGRATION
# ============================================================================
# Pipedrive API key (get from https://app.pipedrive.com/settings/api)
PIPEDRIVE_API_KEY=your-pipedrive-api-key
PIPEDRIVE_BASE_URL=https://api.pipedrive.com/v1

# ============================================================================
# CLAUDE AI API (for matching agents)
# ============================================================================
# Anthropic API key for Claude (get from https://console.anthropic.com)
CLAUDE_API_KEY=sk-ant-xxx

# ============================================================================
# LOGGING & MONITORING (Optional)
# ============================================================================
# Sentry DSN for error tracking (optional but recommended)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/xxxxx

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# DEPLOYMENT-SPECIFIC NOTES
# ============================================================================
# For Render Deployment:
# 1. Create PostgreSQL Database on Render
# 2. Copy the connection string to DATABASE_URL
# 3. Generate a secure SECRET_KEY and set it
# 4. Set FRONTEND_URL to your Vercel frontend domain
# 5. Add Azure credentials for email scanning
# 6. Add Pipedrive and Claude API keys
#
# For Railway Deployment:
# - Similar process, connection string format may differ
#
# For Local Docker Deployment:
# - Use docker-compose.prod.yml which creates PostgreSQL container
# - DATABASE_URL will be: postgresql://postgres:postgres@postgres:5432/panda_vision
